# Ferry configuration. Copy to `.env` and fill in.
# Every value can also be passed to createFerry({ ... }) as an override.

# Public origin Ferry is served from (used to build OAuth redirect URIs).
# Falls back to the incoming request's origin if unset.
FERRY_BASE_URL=http://localhost:5173
# Path prefix Ferry is mounted at (default /submit).
# FERRY_BASE_PATH=/submit

# --- Hack Club Auth ---
# Registered callback: <FERRY_BASE_URL><FERRY_BASE_PATH>/hackclub/callback
FERRY_HCA_CLIENT_ID=
FERRY_HCA_CLIENT_SECRET=
# Space/comma-separated. `basic_info` provides the Slack ID (our dedup key).
# FERRY_HCA_SCOPES=name birthdate address verification_status basic_info

# --- Hackatime ---
# required = user must connect Hackatime; off = skip the step entirely.
FERRY_HACKATIME_MODE=required
# Registered callback: <FERRY_BASE_URL><FERRY_BASE_PATH>/hackatime/callback
FERRY_HACKATIME_CLIENT_ID=
FERRY_HACKATIME_CLIENT_SECRET=
# FERRY_HACKATIME_SCOPES=profile read

# --- Airtable ---
FERRY_AIRTABLE_API_KEY=
FERRY_AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# --- Fillout ---
FERRY_FILLOUT_FORM_URL=https://forms.hackclub.com/your-program

# --- Session ---
# Secret used to derive the cookie encryption key. Must be >= 32 characters.
# Generate one with: openssl rand -hex 32
FERRY_SESSION_SECRET=
