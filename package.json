{
  "name": "ferry",
  "version": "0.0.0",
  "description": "Framework-agnostic library that automates the Hack Club YSWS submission flow.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "sandbox:setup": "(cd sandbox/vite && bun run setup) && (cd sandbox/sveltekit && bun run setup) && (cd sandbox/nextjs && bun run setup) && (cd sandbox/workers && bun run setup)",
    "sandbox:vite": "cd sandbox/vite && bun run dev",
    "sandbox:sveltekit": "cd sandbox/sveltekit && bun run dev",
    "sandbox:nextjs": "cd sandbox/nextjs && bun run dev",
    "sandbox:workers": "cd sandbox/workers && bun run dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/node": "^26.1.1",
    "tsdown": "^0.15.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
